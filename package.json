{
  "name": "crumb",
  "version": "0.1.0",
  "description": "Crumb — open format for travel itineraries",
  "scripts": {
    "render": "ts-node src/cli.ts",
    "build": "ts-node --transpile-only scripts/build-site.ts",
    "build:viewer": "ts-node src/cli.ts examples/japan-detailed.crumb dist/viewer.html",
    "gen:geocache": "ts-node --transpile-only scripts/gen-geocache.ts",
    "typecheck": "node_modules/.bin/tsc --noEmit",
    "test": "node_modules/.bin/vitest run",
    "test:watch": "node_modules/.bin/vitest"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.7",
    "codemirror": "^6.0.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}

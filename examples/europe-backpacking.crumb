trip:
  name: Europe Backpacking
  author: Luca Ferretti
  tags: [europe, backpacking, budget, trains, hostels]
  note: Rail pass covers most legs. Book hostels at least a week ahead in summer — dorms fill fast.

itinerary:

  - Amsterdam:
      arrives: early June 2026
      stay:
        - Stayokay Vondelpark
      activities:
        - day:
            title: Arrival & Jordaan
            items:
              - Check in and drop bags
              - Jordaan neighbourhood walk:
                  priority: must
              - Albert Cuyp Market:
                  time: morning
              - Heineken Experience:
                  priority: maybe

        - day:
            title: Museums
            items:
              - Rijksmuseum:
                  priority: must
              - Van Gogh Museum:
                  priority: must
                  note: Book tickets online the day before — always sells out.
              - Leidseplein for dinner:
                  time: evening

        - day:
            title: Day trip to Haarlem
            items:
              - Train to Haarlem:
                  time: morning
              - Frans Hals Museum:
                  priority: maybe
              - Grote Markt:
                  note: Much quieter than Amsterdam. Good for people-watching.

  - train

  - Berlin:
      stay:
        - Generator Berlin Mitte
      activities:
        - East Side Gallery:
            priority: must
        - Checkpoint Charlie:
            priority: maybe
        - Mauerpark flea market:
            time: morning
            note: Sunday only. Get there early for the good stuff.
            priority: must
        - Kreuzberg street food:
            time: evening
            priority: must

        - day:
            title: History day
            items:
              - Memorial to the Murdered Jews of Europe:
                  priority: must
              - Topography of Terror:
                  priority: must
              - Reichstag dome:
                  priority: must
                  note: Free but must be booked online weeks in advance.

  - train

  - Prague:
      stay:
        - Sophie's Hostel
      activities:
        - Charles Bridge at sunrise:
            time: early morning
            priority: must
            note: Go before 7am — you'll have it almost to yourself.
        - Old Town Square:
            priority: must
        - Vinohrady neighbourhood:
            note: Skip the tourist centre for lunch. Head here instead.

        - day:
            title: Castle & Malá Strana
            items:
              - Prague Castle:
                  time: 9am
                  priority: must
              - Lobkowicz Palace:
                  priority: maybe
              - Malá Strana backstreets:
                  time: afternoon

  - train

  - Vienna:
      stay:
        - Wombats City Hostel
      activities:
        - Schönbrunn Palace:
            priority: must
        - Naschmarkt:
            time: morning
            priority: must
            note: Go hungry. The Turkish and Middle Eastern stalls are the highlight.
        - Belvedere:
            priority: must
            note: The Klimt room alone is worth it.
        - Prater & Riesenrad:
            time: evening
            priority: maybe

  - train

  - Budapest:
      departs: mid July 2026
      stay:
        - Maverick City Lodge
      activities:
        - Széchenyi thermal baths:
            priority: must
            note: Bring flip-flops and a padlock for the locker.
        - Ruin bars in the Jewish Quarter:
            time: evening
            priority: must
        - Fisherman's Bastion:
            time: early morning
            priority: must
            note: Free before 9am. Views over the Danube are best at dawn.

        - day:
            title: Buda side
            items:
              - Buda Castle:
                  priority: must
              - Hungarian National Gallery:
                  priority: maybe
              - Gellért Hill viewpoint:
                  time: late afternoon

        - day:
            title: Day trip to Eger
            items:
              - Train to Eger:
                  time: 9am
              - Eger Castle:
                  priority: must
              - Valley of the Beautiful Women:
                  note: Try the Bull's Blood wine straight from the cellars.
                  priority: must
